# Vercel KV Configuration
VERCEL_KV_REST_API_URL=https://your-kv-store.kv.vercel-storage.com
VERCEL_KV_REST_API_TOKEN=your_token_here

# JWT Secret for token signing
JWT_SECRET=your_jwt_secret_key_here_minimum_32_chars
RSVP_SECRET=your_rsvp_secret_key_here_minimum_32_chars

# Gmail email delivery for dashboard bulk invitations and RSVP confirmations.
GMAIL_SENDER_EMAIL=akhilaakshaywedding@gmail.com
GMAIL_SENDER_NAME="Akhila & Akshay"
GMAIL_OAUTH_CLIENT_ID=your_google_oauth_client_id
GMAIL_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret
GMAIL_OAUTH_REFRESH_TOKEN=your_google_oauth_refresh_token
SITE_URL=https://your-vercel-app.vercel.app
# Optional: standalone public RSVP site used in guest email links.
RSVP_SITE_URL=https://akhila-akshay-rsvp.vercel.app

# RSVP confirmation SMS through one shared Twilio sender number.
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+15551234567
WEDDING_TIMEZONE=America/Chicago
COMMON_EVENT_ADDRESS="Shared address for Haldi, Sangeet, Marriage, and Vratam"
SANGEETH_EVENT_ADDRESS="Metroplex Event Center, 2305 S. 8th St., Rogers, AR 72758"
SANGEETH_MAP_URL=https://maps.app.goo.gl/mthgUzW9rQT5HZrF9
PELLIKUTHURU_ADDRESS="510 Peach Ave, Centerton, AR 72719"
